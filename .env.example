# Copy to .env and paste your free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Voice replies in Hassan's cloned voice (optional — speaker button is
# hidden without these, and again once the monthly quota runs out).
# Preferred: Cartesia — free instant clone + 20k chars/month free.
#   1. Sign up at https://play.cartesia.ai (free, no card)
#   2. Clone your voice: Voices → Create voice → Instant clone (~10s clip)
#   3. Key: API Keys page · Voice ID: on the cloned voice's detail page
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
# Optional — defaults to sonic-2
# CARTESIA_MODEL=sonic-2

# Alternative: ElevenLabs (cloning needs the $5/mo Starter plan).
# Key: https://elevenlabs.io → Profile → API Keys
# Voice ID: clone your voice at elevenlabs.io/app/voice-lab, copy its ID
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional — defaults to eleven_flash_v2_5 (0.5 credits/char)
# ELEVENLABS_MODEL=eleven_flash_v2_5
